SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...

OLLAMA_BASE_URL=http://10.32.145.143:11434
OLLAMA_CHAT_MODEL=gpt-oss:20b
OLLAMA_EMBED_MODEL=nomic-embed-text
PAPERBOT_TRANSLATION_MODEL=qwen3:14b
PAPERBOT_TRANSLATION_ENABLED=true

PAPERBOT_TOP_K=6
PAPERBOT_SHORT_TOP_K=3
PAPERBOT_DEEP_TOP_K=8
PAPERBOT_MAX_PER_SOURCE=3
PAPERBOT_LOG_LEVEL=INFO
SYNC_NOTIFY_CHANNEL=#paperbot-log
SYNC_NOTIFY_MODE=verbose

PAPER_WATCH_CHANNEL=#paper
PAPER_WATCH_MODE=collect
PAPER_WATCH_DB_PATH=/app/rag_poc/index/paper_watch.sqlite3
PAPER_WATCH_RETENTION_DAYS=180
PAPER_WATCH_SOURCES=arxiv,rss
PAPER_WATCH_CONTACT_EMAIL=
PAPER_WATCH_LOOKBACK_DAYS=7
PAPER_WATCH_MAX_RESULTS=500
PAPER_WATCH_ARXIV_DATE_FILTER=true
PAPER_WATCH_SOURCE_STATS=true
PAPER_WATCH_CROSSREF_ROWS=50
PAPER_WATCH_CROSSREF_MAX_ROWS_PER_QUERY=100
PAPER_WATCH_CROSSREF_MAX_QUERIES=6
PAPER_WATCH_CROSSREF_SLEEP_SECONDS=2
# Paper Watch groups. Use only canonical group names.
PAPER_WATCH_RSS_GROUPS=aps_core,aps_ext_reviews,nature_family,aip_family,japan_physics,iop_optics,nano_2d_materials,broad_high_impact
PAPER_WATCH_RSS_MAX_ITEMS_PER_FEED=100
PAPER_WATCH_RSS_SLEEP_SECONDS=2
PAPER_WATCH_RSS_CROSSREF_FALLBACK=true
PAPER_WATCH_RSS_CROSSREF_FALLBACK_ROWS=50
PAPER_WATCH_RSS_CROSSREF_FALLBACK_MAX_JOURNALS=40
# Optional override:
# PAPER_WATCH_RSS_FEEDS=aps_prl|aps_core|Physical Review Letters|https://feeds.aps.org/rss/recent/prl.xml;nature_physics|nature_family|Nature Physics|https://www.nature.com/nphys.rss
PAPER_WATCH_POST_LIMIT=8
PAPER_WATCH_MIN_SCORE=6
PAPER_WATCH_REPORT_SCOPE=all
PAPER_WATCH_REPORT_TITLE=
PAPER_WATCH_REPORT_GROUPS=
PAPER_WATCH_BILINGUAL_INTRO=true
PAPER_WATCH_INCLUDE_ABSTRACT=false
PAPER_WATCH_VERBOSE_MESSAGE=false
PAPER_WATCH_SUMMARY_MODEL=gpt-oss:20b
PAPER_WATCH_TRANSLATION_MODEL=qwen3:14b
PAPER_WATCH_TRANSLATION_ENABLED=true
PAPER_WATCH_CLASSIFY_WITH_LLM=false
PAPER_WATCH_CLASSIFICATION_MODEL=qwen3:14b
PAPER_WATCH_CLASSIFY_LLM_LIMIT=30
PAPER_WATCH_CLASSIFY_LLM_MIN_SCORE=1
PAPER_WATCH_COLLECT_USE_RAG_SCORE=false
PAPER_WATCH_RAG_AFTER_COLLECT=true
PAPER_WATCH_USE_RAG_SCORE=true
PAPER_WATCH_EMBED_MODEL=nomic-embed-text
PAPER_WATCH_RAG_WEIGHT=8
PAPER_WATCH_RAG_CANDIDATE_LIMIT=100
PAPER_WATCH_RAG_MAX_CHUNKS=3000
PAPER_WATCH_RAG_CHUNKS_PER_SOURCE=2
PAPER_WATCH_RAG_MIN_TERM_SCORE=1

ZOTERO_LIBRARY_TYPE=group
ZOTERO_LIBRARY_ID=
